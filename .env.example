# 0 = real OpenAI generation (when OPENAI_API_KEY is set). 1 = mock only.
NEXT_PUBLIC_DEMO_MODE=0
OPENAI_API_KEY=
# Match the port from `npm run dev` (e.g. 3001 if 3000 is in use)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional later:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
