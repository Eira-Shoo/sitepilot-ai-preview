NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. When set and NEXT_PUBLIC_DEMO_MODE=0, /api/ai/generate-website uses OpenAI.
# When missing or NEXT_PUBLIC_DEMO_MODE=1, generation uses the deterministic mock blueprint.
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
OPENAI_MODEL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

RESEND_API_KEY=
RESEND_FROM="SitePilot <onboarding@resend.dev>"

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Preview: 1 = force mock AI (no OpenAI calls), mock APIs, no login.
# Set to 0 and add OPENAI_API_KEY to enable real OpenAI generation on preview/production.
NEXT_PUBLIC_DEMO_MODE=0

# Optional: Vercel sets VERCEL_URL automatically for metadata fallbacks when NEXT_PUBLIC_APP_URL is unset.
